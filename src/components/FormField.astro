---
interface Props {
  id: string;
  label: string;
  required?: boolean;
  type?: astroHTML.JSX.HTMLInputTypeAttribute;
  autocomplete?: string;
  placeholder?: string;
}
const { id, label, required = false, type = "text", autocomplete, placeholder } = Astro.props;
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-sm font-semibold text-slate-200">
    {label}{required && <span class="text-red-400"> *</span>}
  </label>
  <input
    {id}
    name={id}
    {type}
    autocomplete={autocomplete}
    {placeholder}
    required={required}
    class="form-input"
  />
  <p class="field-error hidden" id={`${id}-error`} role="alert"></p>
</div>

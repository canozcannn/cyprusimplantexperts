---
import { SITE } from "../lib/site";
---

<section id="top" class="hero-gradient relative overflow-hidden">
  <!-- Decorative glows -->
  <div
    class="hero-glow h-[520px] w-[520px] -top-24 -right-24 opacity-30"
    style="background: radial-gradient(circle, #e5d3a1 0%, transparent 70%); position:absolute;"
    aria-hidden="true"
  >
  </div>
  <div
    class="hero-glow h-[400px] w-[400px] bottom-0 -left-20 opacity-20"
    style="background: radial-gradient(circle, #2563eb 0%, transparent 70%); position:absolute;"
    aria-hidden="true"
  >
  </div>
  <div class="hero-dot-grid" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-7xl gap-8 px-4 pt-6 pb-8 sm:px-6 lg:grid-cols-12 lg:gap-8 lg:px-8 lg:pt-10 lg:pb-12">
    <!-- Left: copy -->
    <div class="lg:col-span-7" data-hero-copy>
      <div
        data-hero-item
        class="inline-flex items-center gap-2 rounded-full border border-gold/40 bg-white/5 px-3 py-1.5 text-xs font-semibold tracking-wide text-gold backdrop-blur-sm"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-whatsapp animate-pulse"></span>
        Free advisory · Average reply time under 10 minutes
      </div>

      <h1 data-hero-item class="mt-4 text-3xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-4xl lg:text-4xl">
        Premium Implants & Digital Smile Design in Cyprus —
        <span class="relative inline-block">
          <span class="relative z-10">Independently Vetted</span>
          <span class="absolute inset-x-0 bottom-1 -z-0 h-3 rounded-full bg-gold/50"></span>
        </span>
      </h1>

      <p data-hero-item class="mt-3 max-w-xl text-base leading-relaxed text-slate-300">
        We are an independent advisory service that connects international patients with one of Cyprus's top-rated specialist
        implant clinics — fully digital workflow, European implant systems, transparent fixed pricing.
      </p>

      <!-- Trust bullets -->
      <ul data-hero-item class="mt-4 space-y-1.5 text-sm text-slate-200">
        <li class="flex items-start gap-2">
          <svg
            class="mt-0.5 h-4 w-4 shrink-0 text-gold"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 13l4 4L19 7"></path></svg
          >
          Real clinic credentials shared on WhatsApp before you book.
        </li>
        <li class="flex items-start gap-2">
          <svg
            class="mt-0.5 h-4 w-4 shrink-0 text-gold"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 13l4 4L19 7"></path></svg
          >
          Written treatment plan with fixed pricing — no hidden fees.
        </li>
        <li class="flex items-start gap-2">
          <svg
            class="mt-0.5 h-4 w-4 shrink-0 text-gold"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 13l4 4L19 7"></path></svg
          >
          You pay the clinic directly. Our advisory service is free for patients.
        </li>
      </ul>

      <!-- Price highlights -->
      <div data-hero-item class="mt-4 grid grid-cols-3 gap-3 sm:max-w-lg">
        {
          [
            {
              label: "Implant",
              value: SITE.prices.implants,
              limassol: SITE.limassolPrices.implants,
            },
            {
              label: "All-on-4/6",
              value: SITE.prices.allOn,
              limassol: SITE.limassolPrices.allOn,
            },
            {
              label: "Hollywood Smile",
              value: SITE.prices.hollywood,
              limassol: SITE.limassolPrices.hollywood,
            },
          ].map((p) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.06] px-2.5 py-3 text-center shadow-[var(--shadow-soft)] backdrop-blur-md">
              <div class="text-[9px] font-medium uppercase tracking-wider text-slate-400 truncate">{p.label}</div>
              <div class="mt-0.5 text-[10px] font-semibold text-red-400 line-through opacity-80">{p.limassol}</div>
              <div class="mt-0.5 flex items-baseline justify-center gap-1">
                <span class="text-[9px] uppercase tracking-wider text-gold/70">from</span>
                <span class="text-sm font-extrabold text-white sm:text-base whitespace-nowrap">{p.value}</span>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Hook line -->
      <p data-hero-item class="mt-3 max-w-xl text-base font-medium text-slate-200">
        Send your X-ray or photos and get a fixed-price treatment plan
        <span class="font-bold text-gold">in minutes</span>.
      </p>

      <!-- CTAs -->
      <div data-hero-item class="mt-4 flex flex-col gap-3 sm:flex-row">
        <a
          href="#quote"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-gold px-6 py-4 text-sm font-bold text-navy shadow-[0_4px_24px_rgba(229,211,161,0.35)] transition hover:bg-gold/90 hover:shadow-[0_6px_32px_rgba(229,211,161,0.45)]"
        >
          Get My Fixed Price Plan
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a
          href={SITE.whatsappLink}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-whatsapp px-6 py-4 text-sm font-semibold text-white shadow-[var(--shadow-card)] transition hover:bg-whatsapp-600"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path
              d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.554-5.338 11.89-11.893 11.89a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607z"
            ></path>
          </svg>
          Send My X-ray on WhatsApp
        </a>
      </div>

      <!-- No-risk row -->
      <div data-hero-item class="mt-2 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-slate-400">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-whatsapp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            ><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg
          >
          No obligation
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-whatsapp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            ><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg
          >
          No upfront payment
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-whatsapp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            ><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg
          >
          You decide after seeing your plan
        </span>
      </div>

      <!-- Trust badges -->
      <div data-hero-item class="mt-3 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <div class="flex items-center gap-2">
          <div class="flex text-gold">
            {
              [0, 1, 2, 3, 4].map(() => (
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 14.9l-5.2 2.9 1-5.9L1.5 7.7l5.9-.9z" />
                </svg>
              ))
            }
          </div>
          <span class="font-semibold text-white">{SITE.rating}★</span>
          <span class="text-slate-400">Verified Google Reviews</span>
        </div>
        <div class="text-slate-300">
          <span class="font-semibold text-white">{SITE.reviews}</span> patients
        </div>
        <div class="text-slate-400">European implant systems</div>
        <div class="text-slate-400">English-Speaking Support</div>
      </div>
    </div>

    <!-- Right: visual -->
    <div class="relative lg:col-span-5" data-animate="slide-right">
      <div
        class="relative aspect-[4/5] w-full overflow-hidden rounded-3xl border border-white/10 shadow-[0_20px_60px_rgba(0,0,0,0.5)]"
        style="background: linear-gradient(135deg, #1e2d4a 0%, #0f172a 100%);"
      >
        <!-- Subtle inner glow -->
        <div
          class="absolute inset-0"
          style="background: radial-gradient(ellipse 70% 60% at 50% 30%, rgba(229,211,161,0.12), transparent);"
          aria-hidden="true"
        >
        </div>
        <div class="absolute inset-0 grid grid-cols-2" aria-hidden="true">
          <div class="relative">
            <span
              class="absolute left-3 top-3 rounded-full bg-white/15 backdrop-blur px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-slate-300"
              >Before</span
            >
          </div>
          <div class="relative border-l border-white/10">
            <span
              class="absolute right-3 top-3 rounded-full bg-gold/20 backdrop-blur px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-gold"
              >After</span
            >
          </div>
        </div>
        <!-- Placeholder smile icon -->
        <div class="absolute inset-0 grid place-items-center">
          <div class="flex flex-col items-center gap-2 opacity-20">
            <svg class="h-20 w-20 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M8 14s1.5 2 4 2 4-2 4-2" stroke-linecap="round"></path>
              <path d="M9 9h.01M15 9h.01" stroke-linecap="round" stroke-width="2"></path>
            </svg>
            <span class="text-xs text-gold font-medium tracking-widest uppercase">Before / After</span>
          </div>
        </div>
      </div>

      <!-- Floating card -->
      <div
        class="absolute bottom-4 left-2 w-64 rounded-2xl border border-white/10 bg-white/8 p-3.5 shadow-[var(--shadow-card)] backdrop-blur-xl"
      >
        <div class="flex items-center gap-3">
          <div class="grid h-10 w-10 place-items-center rounded-xl bg-gold/20 text-gold">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 1v22M5 8h11a3 3 0 010 6H8a3 3 0 000 6h11" stroke-linecap="round"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold text-white">From €450 implants</div>
            <div class="text-xs text-slate-400">Clear pricing before you travel</div>
          </div>
        </div>
      </div>

      <!-- Floating badge top -->
      <div
        class="absolute -top-6 right-2 hidden rounded-2xl border border-white/10 bg-white/8 px-4 py-3 shadow-(--shadow-card) backdrop-blur-xl md:block"
      >
        <div class="flex items-center gap-2">
          <span class="grid h-8 w-8 place-tems-center rounded-lg bg-whatsapp/20">
            <svg class="h-4 w-4 text-whatsapp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
          <div>
            <div class="text-xs font-bold text-white">No consultation fee</div>
            <div class="text-[10px] text-slate-400">Reply within minutes</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

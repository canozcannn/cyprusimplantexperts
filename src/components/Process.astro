---
import { SITE } from "../lib/site";

const steps = [
  {
    n: "01",
    title: "Send your X-ray",
    desc: "Send X-ray or photos on WhatsApp. No consultation fee.",
  },
  {
    n: "02",
    title: "Get your plan",
    desc: "Receive a personalized treatment plan with transparent pricing.",
  },
  {
    n: "03",
    title: "Visit Cyprus",
    desc: "We coordinate transfers, hotels and your full treatment timeline.",
  },
  {
    n: "04",
    title: "Long-term follow-up",
    desc: "Continuous WhatsApp support after you fly home.",
  },
];
---

<section class="bg-soft py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl" data-animate="fade-up">
      <div class="text-xs font-semibold uppercase tracking-widest text-medical">Simple process</div>
      <h2 class="accent-line mt-3 text-3xl font-bold tracking-tight text-navy sm:text-4xl">4 steps to your new smile</h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-animate-stagger>
      {
        steps.map((s, i) => (
          <div class="relative rounded-3xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-soft)]">
            <div class="text-sm font-bold tracking-widest text-gold">{s.n}</div>
            <h3 class="mt-3 text-lg font-bold text-navy">{s.title}</h3>
            <p class="mt-2 text-sm text-slate-600">{s.desc}</p>
            {i < 3 && (
              <div class="absolute right-4 top-6 hidden text-slate-200 lg:block">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
            )}
          </div>
        ))
      }
    </div>

    <div class="mt-10 flex justify-center">
      <a
        href={SITE.whatsappLink}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-whatsapp px-6 py-3.5 text-sm font-semibold text-white shadow-[var(--shadow-card)] transition hover:bg-whatsapp-600"
      >
        Start on WhatsApp — Get your plan
      </a>
    </div>
  </div>
</section>

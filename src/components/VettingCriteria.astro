---
import { SITE } from "../lib/site";

const criteria = [
  {
    title: "100+ verified Google reviews",
    desc: "We only partner with clinics that hold a long, public track record of patient satisfaction.",
    icon: `<path d="M12 2l2.6 5.3 5.9.9-4.3 4.2 1 5.9L12 15.4l-5.2 2.9 1-5.9-4.3-4.2 5.9-.9z"/>`,
  },
  {
    title: "European implant systems only",
    desc: "Premium German, Swiss and Italian implant brands with global parts availability and long-term clinical evidence.",
    icon: `<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"/>`,
  },
  {
    title: "100% digital workflow",
    desc: "Intraoral scanners, guided surgery and CAD/CAM production. No analogue impressions, no guesswork.",
    icon: `<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 21h8M12 18v3M7 9h10M7 13h6"/>`,
  },
  {
    title: "Experienced with international patients",
    desc: "Dedicated coordination, English communication and accelerated timelines designed for travelling patients.",
    icon: `<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0116 0"/>`,
  },
  {
    title: "Transparent, fixed pricing",
    desc: "Written quotes with no hidden surcharges. The price you receive on WhatsApp is the price at the clinic.",
    icon: `<rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3 10h18M7 15h4"/>`,
  },
  {
    title: "Independent quality reviews",
    desc: "We re-audit every partner clinic regularly and remove any clinic that drops below our quality standard.",
    icon: `<path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/>`,
  },
];
---

<section id="how-we-vet" class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center" data-animate="fade-up">
      <div class="text-xs font-semibold uppercase tracking-widest text-medical">Our advisory standard</div>
      <h2 class="accent-line-center mt-3 text-3xl font-bold tracking-tight text-navy sm:text-4xl">
        How we choose our partner clinics
      </h2>
      <p class="mt-4 text-base text-slate-600">
        We are an independent advisory service. We do not own clinics — we vet them. Every clinic in our network must meet
        all six criteria below before we recommend them to a patient.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-animate-stagger>
      {
        criteria.map((c) => (
          <div class="flex h-full flex-col rounded-3xl border border-slate-200 bg-soft p-6 transition hover:-translate-y-1 hover:bg-white hover:shadow-[var(--shadow-soft)]">
            <div class="grid h-11 w-11 place-items-center rounded-2xl bg-medical/10 text-medical">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={c.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-base font-bold text-navy">{c.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{c.desc}</p>
          </div>
        ))
      }
    </div>

    <div
      class="mx-auto mt-10 flex max-w-3xl flex-col items-start justify-between gap-4 rounded-2xl border border-slate-200 bg-soft px-6 py-5 sm:flex-row sm:items-center"
      data-animate="fade-up"
    >
      <div class="text-sm text-slate-700">
        <div class="font-semibold text-navy">Already have a quote from another clinic?</div>
        <div class="mt-1 text-slate-600">Send it to us — we'll review it and tell you honestly how it compares.</div>
      </div>
      <a
        href={SITE.whatsappLink}
        target="_blank"
        rel="noopener"
        class="inline-flex shrink-0 items-center gap-2 rounded-full bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:bg-charcoal"
      >
        Get a Second Opinion
      </a>
    </div>
  </div>
</section>

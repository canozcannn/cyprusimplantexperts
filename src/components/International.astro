---
const features = [
  {
    title: "Accommodation support",
    desc: "Curated hotel options near your treatment, at every budget.",
    // Lucide Home
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/>`,
  },
  {
    title: "Airport transfers",
    desc: "Door-to-door transfer support for a stress-free arrival.",
    // Lucide Plane (overhead view)
    icon: `<path d="M21 16V14L13 9V3.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5V9L3 14v2l9-2.5V19l-2 1.5V22l3-1 3 1v-1.5L13 19v-5.5L21 16z"/>`,
  },
  {
    title: "Fast timeline",
    desc: "Optimized scheduling so you can finish treatment in fewer trips.",
    // Lucide Clock
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: "English support",
    desc: "Full English communication from first message to final follow-up.",
    // Lucide Globe
    icon: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>`,
  },
  {
    title: "WhatsApp follow-up",
    desc: "Long-term care, photos and questions — answered fast on WhatsApp.",
    // Lucide MessageCircle
    icon: `<path d="M7.9 20A9 9 0 104 16.1L2 22z"/>`,
  },
];
---

<section class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl" data-animate="fade-up">
      <div class="text-xs font-semibold uppercase tracking-widest text-medical">International experience</div>
      <h2 class="accent-line mt-3 text-3xl font-bold tracking-tight text-navy sm:text-4xl">
        Built around international patients
      </h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-5" data-animate-stagger>
      {
        features.map((f) => (
          <div class="rounded-3xl border border-slate-200 bg-soft p-6 transition hover:-translate-y-1 hover:bg-white hover:shadow-[var(--shadow-soft)]">
            <div class="grid h-11 w-11 place-items-center rounded-2xl bg-medical/10 text-medical">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={f.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-base font-bold text-navy">{f.title}</h3>
            <p class="mt-1 text-sm text-slate-600">{f.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

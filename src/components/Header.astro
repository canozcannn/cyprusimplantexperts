---
import { SITE } from "../lib/site";
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200/70 bg-white/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="#top" class="flex items-center gap-2">
      <span class="grid h-9 w-9 place-items-center rounded-xl bg-navy text-gold" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5">
          <path
            d="M12 2c-3 0-5 2-5 5 0 2 .5 3 1 5s.5 4 0 6 1 4 2 4 1.5-2 2-4 1-2 2 0 1 4 2 4 2.5-2 2-4-.5-4 0-6 1-3 1-5c0-3-2-5-5-5-1 0-1.5.5-2 1-.5-.5-1-1-2-1z"
            fill="currentColor"></path>
        </svg>
      </span>
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="text-sm font-bold tracking-tight text-navy">Premium Dental Implants Cyprus</span>
        <span class="text-[11px] text-slate-500">{SITE.advisorLabel}</span>
      </span>
      <span class="sm:hidden text-sm font-bold tracking-tight text-navy">Implants Cyprus</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm font-medium text-slate-700">
      <a class="hover:text-medical transition" href="#implants">Implants</a>
      <a class="hover:text-medical transition" href="#hollywood">Hollywood Smile</a>
      <a class="hover:text-medical transition" href="#workflow">Digital Workflow</a>
      <a class="hover:text-medical transition" href="#results">Results</a>
      <a class="hover:text-medical transition" href="#faq">FAQ</a>
      <a class="hover:text-medical transition font-semibold text-medical" href="#quote-form">Get a Quote</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={SITE.whatsappLink}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full bg-whatsapp px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-whatsapp-600 hover:shadow-md"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path
            d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.554-5.338 11.89-11.893 11.89a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.371-.025-.52-.075-.149-.669-1.611-.916-2.206-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"
          ></path>
        </svg>
        <span class="hidden sm:inline">WhatsApp Consultation</span>
        <span class="sm:hidden">WhatsApp</span>
      </a>
    </div>
  </div>
</header>

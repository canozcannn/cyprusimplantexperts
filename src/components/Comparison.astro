---
const cheap = [
  "Surprise costs added on arrival",
  "Generic, low-cost implant brands",
  "Manual impressions and analogue workflow",
  "Limited post-op follow-up",
  "Unclear English communication",
  "Rushed timeline, no written plan upfront",
];

const premium = [
  "Fixed, written quote before you travel",
  "German / Swiss / Italian implant systems",
  "100% digital workflow with guided surgery",
  "Long-term WhatsApp follow-up after you fly home",
  "Dedicated English-speaking advisory coordinator",
  "Realistic plan based on your X-ray, not a template",
];
---

<section class="bg-soft py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center" data-animate="fade-up">
      <div class="text-xs font-semibold uppercase tracking-widest text-medical">Why patients choose us</div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-navy sm:text-4xl">
        Budget-focused clinics vs. premium price-performance
      </h2>
      <p class="mt-4 text-base text-slate-600">We focus on long-term outcomes — not the lowest possible quote.</p>
    </div>

    <div class="mt-12 grid gap-5 lg:grid-cols-2" data-animate-stagger>
      <div class="rounded-3xl border border-slate-200 bg-white p-7">
        <div class="flex items-center gap-2">
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-500"> Budget-focused clinics </span>
        </div>
        <ul class="mt-6 space-y-3">
          {
            cheap.map((c) => (
              <li class="flex items-start gap-3 text-sm text-slate-600">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-red-50 text-red-500">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
                  </svg>
                </span>
                {c}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative rounded-3xl border-2 border-gold bg-white p-7 shadow-[var(--shadow-card)]">
        <div class="flex items-center gap-2">
          <span class="rounded-full bg-navy px-3 py-1 text-xs font-semibold text-gold"> Our Vetted Partner Clinic </span>
        </div>
        <ul class="mt-6 space-y-3">
          {
            premium.map((p) => (
              <li class="flex items-start gap-3 text-sm text-navy">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-whatsapp/10 text-whatsapp">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="font-medium">{p}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

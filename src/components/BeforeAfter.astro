---
import { SITE } from "../lib/site";

const cases = [
  {
    title: "Full-arch zirconia restoration",
    materials: "German implants · monolithic zirconia bridge",
    duration: "5–7 days · 2 visits",
  },
  {
    title: "Hollywood Smile (upper arch)",
    materials: "10 zirconia veneers · digital smile design",
    duration: "5–7 days · 1 visit",
  },
  {
    title: "All-on-6 with immediate loading",
    materials: "Swiss implants · titanium bar framework",
    duration: "7 days first visit · final delivery in 3–4 months",
  },
];
---

<section id="results" class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end" data-animate="fade-up">
      <div>
        <div class="text-xs font-semibold uppercase tracking-widest text-medical">Real Results</div>
        <h2 class="accent-line mt-3 text-3xl font-bold tracking-tight text-navy sm:text-4xl">Before & after</h2>
        <p class="mt-3 max-w-xl text-base text-slate-600">A glimpse of real transformations created with our digital workflow.</p>
      </div>
      <a
        href={SITE.whatsappLink}
        target="_blank"
        rel="noopener"
        class="hidden rounded-full bg-navy px-6 py-3 text-sm font-semibold text-white transition hover:bg-charcoal sm:inline-flex"
      >
        See real results
      </a>
    </div>

    <!-- Slider -->
    <div class="mt-10 -mx-4 overflow-x-auto px-4 no-scrollbar sm:mx-0 sm:px-0" data-animate="fade-up" data-animate-delay="150">
      <div class="flex gap-5 sm:grid sm:grid-cols-3 sm:gap-5">
        {
          cases.map((c, i) => (
            <div class="relative w-[85%] shrink-0 overflow-hidden rounded-3xl border border-slate-200 shadow-[var(--shadow-soft)] sm:w-auto">
              <div class="ba-placeholder aspect-[4/3] w-full">
                <div class="absolute left-3 top-3 rounded-full bg-white/95 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-slate-700">
                  Case {i + 1}
                </div>
                <div class="absolute right-3 top-3 rounded-full bg-navy/95 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-gold">
                  After
                </div>
              </div>
              <div class="bg-white p-4">
                <div class="text-sm font-semibold text-navy">{c.title}</div>
                <div class="mt-1 text-xs text-slate-500">{c.materials}</div>
                <div class="mt-0.5 text-xs text-slate-500">{c.duration}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

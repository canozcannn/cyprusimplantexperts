---
import { SITE } from "../lib/site";
import { countries as countriesData } from "countries-list";
import FormField from "./FormField.astro";

const treatments = [
  "Single Dental Implant",
  "Multiple Dental Implants",
  "All-on-4 / All-on-6 (Full Arch)",
  "Hollywood Smile (Zirconia Veneers)",
  "Zirconia Crown(s)",
  "Full Mouth Rehabilitation",
  "Digital Smile Design",
  "Not sure yet — I need advice",
];

const timings = ["As soon as possible", "Within 1–3 months", "Within 3–6 months", "Within 6–12 months", "Just exploring for now"];

// Popular countries pinned at the top (dental tourism context: UK, EU, Anglophone, Med)
const popularCodes = ["CY", "GB", "CA", "AU", "DE", "NL", "SE", "NO", "DK", "CH"];

type CountryEntry = { name: string };
const popular = popularCodes
  .map((c) => (countriesData as Record<string, CountryEntry>)[c]?.name)
  .filter((n): n is string => Boolean(n));
const rest = Object.entries(countriesData as Record<string, CountryEntry>)
  .filter(([code]) => !popularCodes.includes(code))
  .map(([, c]) => c.name)
  .sort((a, b) => a.localeCompare(b));
---

<section id="quote-form" class="dark-gradient relative overflow-hidden py-16 sm:py-24">
  <div
    class="pointer-events-none absolute -top-32 -right-32 h-120 w-120 rounded-full opacity-[0.07]"
    style="background: radial-gradient(circle, #e5d3a1, transparent 70%); filter: blur(40px);"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center" data-animate="fade-up">
      <div class="text-xs font-semibold uppercase tracking-widest text-gold">Free fixed-price treatment plan</div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">Get Your Personalised Quote</h2>
      <p class="mx-auto mt-4 max-w-xl text-base text-slate-300">
        Fill in your details and we'll send a clear, written treatment plan with fixed pricing — plus the full clinic profile — straight to your WhatsApp.
      </p>
      <p class="mx-auto mt-3 max-w-md text-xs text-slate-400">
        Our advisory service is completely free to patients. We work with vetted partner clinics on a referral basis — you pay exactly the same price as walking in directly.
      </p>
    </div>

    <div
      class="mx-auto mt-8 flex max-w-2xl flex-col items-start justify-between gap-4 rounded-2xl border border-gold/30 bg-white/5 p-5 backdrop-blur sm:flex-row sm:items-center"
      data-animate="fade-up"
    >
      <div class="text-sm text-slate-200">
        <div class="font-semibold text-gold">Already have a quote?</div>
        <div class="mt-1 text-slate-300">Send it to us — we'll review and compare it for you, honestly.</div>
      </div>
      <a
        href={SITE.whatsappLink}
        target="_blank"
        rel="noopener"
        class="inline-flex shrink-0 items-center gap-2 rounded-full bg-white/10 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20"
      >
        Get a Second Opinion
      </a>
    </div>

    <form
      id="quoteForm"
      novalidate
      data-whatsapp={SITE.whatsappNumber}
      class="mt-10 rounded-3xl border border-white/10 bg-white/4 p-6 shadow-[0_20px_60px_rgba(0,0,0,0.35)] backdrop-blur-md sm:p-8"
      data-animate="fade-up"
    >
      <!-- Name -->
      <FormField id="fullName" label="Full Name" required autocomplete="name" placeholder="e.g. Sarah Johnson" />

      <!-- Contact row -->
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <FormField id="email" label="Email Address" required type="email" autocomplete="email" placeholder="sarah@example.com" />
        <FormField id="whatsapp" label="WhatsApp Number" required type="tel" autocomplete="tel" placeholder="+44 7700 900000" />
      </div>

      <!-- Treatment -->
      <div class="mt-4 flex flex-col gap-1.5">
        <label for="treatment" class="text-sm font-semibold text-slate-200">
          Treatment I'm interested in <span class="text-red-400">*</span>
        </label>
        <div class="select-wrap">
          <select id="treatment" name="treatment" class="form-input form-select" required>
            <option value="">Select a treatment…</option>
            {treatments.map((t) => <option value={t}>{t}</option>)}
          </select>
        </div>
        <p class="field-error hidden" id="treatment-error" role="alert"></p>
      </div>

      <!-- Country -->
      <div class="mt-4 flex flex-col gap-1.5">
        <label for="country" class="text-sm font-semibold text-slate-200">
          Where are you travelling from? <span class="text-red-400">*</span>
        </label>
        <div class="select-wrap">
          <select id="country" name="country" class="form-input form-select" required>
            <option value="">Select your country…</option>
            <optgroup label="Popular">
              {popular.map((n) => <option value={n}>{n}</option>)}
            </optgroup>
            <optgroup label="All countries">
              {rest.map((n) => <option value={n}>{n}</option>)}
            </optgroup>
          </select>
        </div>
        <p class="field-error hidden" id="country-error" role="alert"></p>
      </div>

      <!-- Timing (optional) -->
      <div class="mt-4 flex flex-col gap-1.5">
        <label for="timing" class="text-sm font-semibold text-slate-200">
          When are you thinking of treatment?
          <span class="ml-1 text-xs font-normal text-slate-400">(optional)</span>
        </label>
        <div class="select-wrap">
          <select id="timing" name="timing" class="form-input form-select">
            <option value="">No preference</option>
            {timings.map((t) => <option value={t}>{t}</option>)}
          </select>
        </div>
      </div>

      <!-- Optional services -->
      <fieldset class="mt-6">
        <legend class="text-sm font-semibold text-slate-200">
          Additional support needed
          <span class="ml-1 text-xs font-normal text-slate-400">(optional)</span>
        </legend>
        <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:gap-6">
          <label class="form-checkbox-label">
            <input type="checkbox" name="hotel" class="form-checkbox" />
            <svg
              class="h-4 w-4 text-medical shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
              <path d="M9 22V12h6v10"></path>
            </svg>
            Hotel / Accommodation
          </label>
          <label class="form-checkbox-label">
            <input type="checkbox" name="transfer" class="form-checkbox" />
            <svg
              class="h-4 w-4 text-medical shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M21 16V14L13 9V3.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5V9L3 14v2l9-2.5V19l-2 1.5V22l3-1 3 1v-1.5L13 19v-5.5L21 16z"
              ></path>
            </svg>
            Airport Transfer
          </label>
        </div>
      </fieldset>

      <!-- Submit -->
      <button
        type="submit"
        class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full bg-whatsapp px-6 py-4 text-base font-semibold text-white shadow-(--shadow-card) transition hover:opacity-90 active:scale-95"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0" fill="currentColor">
          <path
            d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.554-5.338 11.89-11.893 11.89a11.9 11.9 0 01-5.688-1.448L.057 24z"
          ></path>
        </svg>
        Send via WhatsApp
      </button>
      <p class="mt-3 text-center text-xs text-slate-500">
        No obligation. No upfront payment. You decide after seeing your plan.
      </p>
    </form>
  </div>
</section>

<style>
  .form-input {
    width: 100%;
    border-radius: 0.875rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.07);
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    color: #f1f5f9;
    outline: none;
    transition:
      border-color 0.15s,
      box-shadow 0.15s,
      background 0.15s;
  }
  .form-input::placeholder {
    color: #64748b;
  }
  .form-input:focus {
    border-color: rgba(99, 153, 255, 0.6);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
    background: rgba(255, 255, 255, 0.1);
  }
  .form-input.error {
    border-color: rgba(248, 113, 113, 0.7);
    box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.15);
  }
  .field-error {
    font-size: 0.75rem;
    color: #f87171;
    margin-top: 0.25rem;
  }

  /* Native select */
  .select-wrap {
    position: relative;
  }
  .form-select {
    appearance: none;
    padding-right: 2.25rem;
    cursor: pointer;
  }
  .form-select option,
  .form-select optgroup {
    background: #1e293b;
    color: #f1f5f9;
  }
  .select-wrap::after {
    content: "";
    position: absolute;
    right: 0.875rem;
    top: 50%;
    translate: 0 -50%;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #64748b;
    pointer-events: none;
  }

  .form-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #cbd5e1;
    cursor: pointer;
    user-select: none;
  }
  .form-checkbox {
    width: 1rem;
    height: 1rem;
    border-radius: 0.25rem;
    accent-color: #2563eb;
    cursor: pointer;
    flex-shrink: 0;
  }
</style>

<script>
  import * as v from "valibot";

  const Schema = v.object({
    fullName: v.pipe(v.string(), v.trim(), v.minLength(2, "Please enter your full name.")),
    email: v.pipe(v.string(), v.trim(), v.email("Please enter a valid email address.")),
    whatsapp: v.pipe(
      v.string(),
      v.trim(),
      v.minLength(7, "WhatsApp number is required."),
      v.regex(/^\+?[\d\s()\-.]+$/, "Please enter a valid phone number."),
    ),
    treatment: v.pipe(v.string(), v.minLength(1, "Please select a treatment.")),
    country: v.pipe(v.string(), v.minLength(1, "Please select your country.")),
  });

  const field = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
  const errEl = (id: string) => document.getElementById(`${id}-error`);

  function setError(id: string, msg: string) {
    field(id)?.classList.add("error");
    const el = errEl(id);
    if (el) {
      el.textContent = msg;
      el.classList.remove("hidden");
    }
  }
  function clearError(id: string) {
    field(id)?.classList.remove("error");
    const el = errEl(id);
    if (el) {
      el.textContent = "";
      el.classList.add("hidden");
    }
  }

  ["fullName", "email", "whatsapp", "treatment", "country"].forEach((id) =>
    field(id)?.addEventListener("input", () => clearError(id)),
  );

  const form = document.getElementById("quoteForm") as HTMLFormElement | null;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const raw = Object.fromEntries(new FormData(form).entries());

    const result = v.safeParse(Schema, {
      fullName: String(raw.fullName ?? ""),
      email: String(raw.email ?? ""),
      whatsapp: String(raw.whatsapp ?? ""),
      treatment: String(raw.treatment ?? ""),
      country: String(raw.country ?? ""),
    });

    if (!result.success) {
      const seen = new Set<string>();
      let first: string | null = null;
      for (const issue of result.issues) {
        const f = issue.path?.[0]?.key as string | undefined;
        if (f && !seen.has(f)) {
          seen.add(f);
          if (!first) first = f;
          setError(f, issue.message);
        }
      }
      if (first) {
        field(first)?.focus();
        field(first)?.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
      return;
    }

    const d = result.output;
    const extras: string[] = [];
    if (raw.hotel) extras.push("✅ Hotel / Accommodation");
    if (raw.transfer) extras.push("✅ Airport Transfer");

    const lines = [
      `👋 Hello, I'd like a free, fixed-price treatment plan.`,
      ``,
      `👤 *Name:* ${d.fullName}`,
      `📧 *Email:* ${d.email}`,
      `📱 *WhatsApp:* ${d.whatsapp}`,
      `🦷 *Treatment:* ${d.treatment}`,
      `✈️ *Travelling from:* ${d.country}`,
    ];
    if (raw.timing) lines.push(`📅 *Preferred timing:* ${raw.timing}`);
    if (extras.length) {
      lines.push(`🏨 *Also interested in:*`);
      extras.forEach((x) => lines.push(`   ${x}`));
    }
    lines.push(``, `Please send me my personalised quote. Thank you!`);

    const number = (form.dataset.whatsapp ?? "").replace(/\D/g, "");
    window.open(`https://wa.me/${number}?text=${encodeURIComponent(lines.join("\n"))}`, "_blank", "noopener,noreferrer");
  });
</script>

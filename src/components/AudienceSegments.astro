---
import { SITE } from "../lib/site";

const segments = [
  {
    flag: "🇬🇧",
    title: "UK Patients",
    text: "Typically 60–70% lower than UK private clinics. Direct flights, English coordination and a clear written quote before you decide to travel.",
    cta: "Get a UK Comparison Quote",
  },
  {
    flag: "🇨🇾",
    title: "Greek Cypriot Patients",
    text: "Local-friendly service with premium European materials and a fixed, written quote you can review with your family before deciding.",
    cta: "Δωρεάν Εκτίμηση",
  },
  {
    flag: "🌍",
    title: "Expats in Cyprus",
    text: "Full English communication, fast scheduling and an international-standard digital workflow — with the same fixed pricing as locals.",
    cta: "Ask About My Case",
  },
];
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl" data-animate="fade-up">
      <div class="text-xs font-semibold uppercase tracking-widest text-medical">Built for international patients</div>
      <h2 class="accent-line mt-3 text-3xl font-bold tracking-tight text-navy sm:text-4xl">Who is this for?</h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3" data-animate-stagger>
      {
        segments.map((s) => (
          <div class="group relative overflow-hidden rounded-3xl border border-slate-200 bg-soft p-7 transition hover:-translate-y-1 hover:border-gold hover:shadow-[var(--shadow-card)]">
            <div class="text-3xl">{s.flag}</div>
            <h3 class="mt-4 text-xl font-bold text-navy">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.text}</p>
            <a
              href={SITE.whatsappLink}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-medical hover:text-medical-600"
            >
              {s.cta}
              <svg
                class="h-4 w-4 transition group-hover:translate-x-1"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

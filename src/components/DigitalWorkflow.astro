---
const tech = [
  {
    name: "TRIOS 6",
    desc: "High-precision intraoral scanning, no impressions.",
    // Lucide Box — 3D digital model
    icon: `<path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>`,
  },
  {
    name: "AI Smile Design",
    desc: "Preview your final smile before treatment starts.",
    // Lucide ScanFace — AI scan + smile preview
    icon: `<path d="M3 7V5a2 2 0 012-2h2"/><path d="M17 3h2a2 2 0 012 2v2"/><path d="M21 17v2a2 2 0 01-2 2h-2"/><path d="M7 21H5a2 2 0 01-2-2v-2"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/>`,
  },
  {
    name: "Asiga Production",
    desc: "Industry-grade 3D printing for surgical guides & models.",
    // Lucide Layers — stacked 3D print layers
    icon: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  },
];
---

<section id="workflow" class="bg-navy text-white py-16 sm:py-24 dark-gradient">
  <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-12 lg:gap-10 lg:px-8">
    <div class="lg:col-span-6" data-animate="slide-left">
      <div class="text-xs font-semibold uppercase tracking-widest text-gold">Full Digital Workflow</div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Designed digitally. Delivered precisely.</h2>
      <p class="mt-4 max-w-xl text-base text-slate-300">
        From the first scan to the final crown, every step is digital — for higher accuracy, better aesthetics and predictable
        results.
      </p>

      <ul class="mt-8 space-y-4">
        {
          tech.map((t) => (
            <li class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-gold/20 text-gold">
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <Fragment set:html={t.icon} />
                </svg>
              </span>
              <div>
                <div class="font-semibold">{t.name}</div>
                <div class="text-sm text-slate-300">{t.desc}</div>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="relative lg:col-span-6" data-animate="slide-right">
      <div
        class="aspect-video w-full overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-slate-700 to-slate-900 shadow-[var(--shadow-card)]"
      >
        <div class="grid h-full place-items-center">
          <button
            type="button"
            class="group flex items-center gap-3 rounded-full bg-white/10 px-5 py-3 backdrop-blur transition hover:bg-white/20"
            aria-label="Watch the digital workflow video"
          >
            <span class="grid h-12 w-12 place-items-center rounded-full bg-white text-navy">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </span>
            <span class="text-sm font-semibold">Watch the workflow</span>
          </button>
        </div>
      </div>
      <div class="mt-4 flex flex-wrap gap-2 text-xs text-slate-400">
        <span class="rounded-full border border-white/10 px-3 py-1">3D scan</span>
        <span class="rounded-full border border-white/10 px-3 py-1">AI design</span>
        <span class="rounded-full border border-white/10 px-3 py-1">Guided surgery</span>
        <span class="rounded-full border border-white/10 px-3 py-1">Same-trip delivery</span>
      </div>
    </div>
  </div>
</section>
